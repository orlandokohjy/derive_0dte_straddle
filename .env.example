# ── Derive Credentials ──
DERIVE_ENV=PROD              # PROD or TEST
DERIVE_WALLET=0xYourMetaMaskWalletAddress
DERIVE_SESSION_KEY=0xYourSessionKeyPrivateKey
DERIVE_SUBACCOUNT_ID=12345

# ── Strategy ──
DRY_RUN=false
QTY_PER_LEG=1.0
INITIAL_CAPITAL_USD=8000

# ── Telegram (Ops Bot — personal chat) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Telegram (Report Bot — group chat) ──
TELEGRAM_REPORT_BOT_TOKEN=
TELEGRAM_REPORT_CHAT_ID=

# ── Logging ──
LOG_LEVEL=INFO
